# -----------------------------
# XGBoost parameters
# -----------------------------
xgb_params = {
    "objective": "binary:logistic",
    "eval_metric": "logloss",
    "max_depth": 5,
    "learning_rate": 0.03,
    "n_estimators": 1000,
    "subsample": 0.6,
    "colsample_bytree": 0.6,
    "gamma": 1.0,
    "min_child_weight": 5,
    "reg_lambda": 3.0,
    "reg_alpha": 0.5,
    "tree_method": "hist",
    "n_jobs": -1,
    "random_state": 42,
    "early_stopping_rounds": 50
}
# -----------------------------
# Training function
# -----------------------------
def run(sigName, fOutName, backgrounds):
    """Train XGBoost for a signal file and save to ROOT + pickle"""
    # Load signal
    sig_df = load_process(sigName, variables, target=1, weight_sf=weight_sf)

    # Merge with backgrounds
    data = pd.concat([sig_df, backgrounds], ignore_index=True)
    
    data = data.sample(frac=1, random_state=42).reset_index(drop=True)  # shuffle

    # Split train/test
    X_train, X_test, y_train, y_test, w_train, w_test = train_test_split(
        data[variables], data['target'], data['weight'], test_size=0.25, random_state=42
    )

    # Convert to numpy
    X_train, X_test = X_train.to_numpy(), X_test.to_numpy()
    y_train, y_test = y_train.to_numpy(), y_test.to_numpy()
    w_train, w_test = w_train.to_numpy(), w_test.to_numpy()

    # Train XGBoost
    print(f"Training model for {sigName}...")
    eval_set = [(X_train, y_train), (X_test, y_test)]
    bdt = xgb.XGBClassifier(**xgb_params)
    bdt.fit(X_train, y_train, sample_weight=w_train, eval_set=eval_set,  verbose=True)

    # Save to TMVA ROOT
    print(f"Saving TMVA model to {fOutName}.root...")
    ROOT.TMVA.Experimental.SaveXGBoost(bdt, f"bdt_model", fOutName+".root", num_inputs=len(variables))

    # Save variable list in ROOT file
    variables_list = ROOT.TList()
    for var in variables:
        variables_list.Add(ROOT.TObjString(var))
    fOut = ROOT.TFile(fOutName+".root", "UPDATE")
    fOut.WriteObject(variables_list, "variables")
    fOut.Close()

    # Save to pickle
    print(f"Saving pickle {fOutName}.pkl...")
    save = {
        'model': bdt,
        'train_data': X_train,
        'test_data': X_test,
        'train_labels': y_train,
        'test_labels': y_test,
        'train_weights': w_train,
        'test_weights': w_test,
        'variables': variables
    }
    pickle.dump(save, open(fOutName+".pkl", "wb"))
    print("Done.\n")

