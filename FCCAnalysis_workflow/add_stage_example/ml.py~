# -----------------------------
# Load process function
# -----------------------------
def load_process(fIn, variables, target=0, weight_sf=1.):
    """Load a ROOT file, return pandas DataFrame with target and weight"""
    with uproot.open(fIn) as f:
        tree = f["events"]
        n_entries = min(tree.num_entries, max_events)
        
        arrays = tree.arrays(
            variables,
            entry_start=0,
            entry_stop=n_entries,
            library="np"
        )

    df = pd.DataFrame(arrays)
    # Shuffle at load time
    df = df.sample(frac=1, random_state=42).reset_index(drop=True)

    df['target'] = target
    df['weight'] =1# weight_sf / n_entries
    print(f"Loaded {fIn} ({n_entries} events), weight={df['weight'].iloc[0]}")
    return df

